{
  "name": "@minasoft/mcp-runtime",
  "version": "0.1.1",
  "description": "Framework-light TypeScript MCP JSON-RPC runtime contracts.",
  "type": "module",
  "license": "Apache-2.0",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "json-rpc",
    "resources",
    "prompts",
    "tools",
    "nextjs",
    "typescript"
  ],
  "homepage": "https://github.com/stevennana/mina-mock-mcpserver/tree/main/packages/mcp-runtime#readme",
  "bugs": {
    "url": "https://github.com/stevennana/mina-mock-mcpserver/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stevennana/mina-mock-mcpserver.git",
    "directory": "packages/mcp-runtime"
  },
  "engines": {
    "node": ">=20.11"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "pack:dry-run": "npm pack --dry-run",
    "test": "npm run build && node --import tsx --test --test-concurrency=1 \"test/**/*.test.ts\""
  },
  "sideEffects": false
}
