generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Endpoint {
  id                    String          @id
  name                  String          @unique
  title                 String          @default("")
  description           String          @default("")
  enabled               Boolean         @default(true)
  protectedDefault      Boolean         @default(false)
  deleteCode            String?
  defaultResponseJson   String          @default("{}")
  failureMode           String          @default("none")
  failureStatusCode     Int?
  failureDelayMs        Int             @default(0)
  failureMessage        String?
  malformedResponseJson String?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  parameters            EndpointParam[]
  responseCases         ResponseCase[]
}

model EndpointParam {
  id               String   @id
  endpointId       String
  position         Int
  name             String
  label            String?
  description      String   @default("")
  type             String   @default("string")
  required         Boolean  @default(false)
  defaultValueJson String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  endpoint         Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([endpointId, position])
  @@unique([endpointId, name])
  @@index([endpointId])
}

model ResponseCase {
  id              String   @id
  endpointId      String
  name            String
  priority        Int      @default(0)
  matchArgsJson   String   @default("{}")
  responseJson    String
  statusCode      Int      @default(200)
  delayMs         Int      @default(0)
  errorMode       String   @default("none")
  errorStatusCode Int?
  errorMessage    String?
  errorBodyJson   String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  endpoint        Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([endpointId, name])
  @@index([endpointId, priority])
  @@index([endpointId])
}

model AuditEvent {
  id             String   @id
  eventType      String
  subjectType    String
  subjectId      String?
  subjectName    String?
  outcome        String
  actorType      String   @default("public")
  metadataJson   String   @default("{}")
  createdAt      DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([subjectType, subjectId])
}

model BasicUser {
  id           String   @id
  username     String   @unique
  passwordHash String
  enabled      Boolean  @default(true)
  builtIn      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([builtIn, username])
}

model OAuthUser {
  id                    String   @id
  username              String   @unique
  passwordHash          String
  enabled               Boolean  @default(true)
  builtIn               Boolean  @default(false)
  accessTokenTtlSeconds Int      @default(3600)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([builtIn, username])
}
