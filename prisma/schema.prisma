generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Endpoint {
  id                    String                           @id
  name                  String                           @unique
  title                 String                           @default("")
  description           String                           @default("")
  enabled               Boolean                          @default(true)
  protectedDefault      Boolean                          @default(false)
  deleteCode            String?
  defaultResponseJson   String                           @default("{}")
  failureMode           String                           @default("none")
  failureStatusCode     Int?
  failureDelayMs        Int                              @default(0)
  failureMessage        String?
  malformedResponseJson String?
  createdAt             DateTime                         @default(now())
  updatedAt             DateTime                         @updatedAt
  parameters            EndpointParam[]
  responseCases         ResponseCase[]
  oauthClientAllowances OAuthClientAllowedEndpoint[]
  oauthCodePermissions  OAuthAuthorizationCodeEndpoint[]
}

model EndpointParam {
  id               String   @id
  endpointId       String
  position         Int
  name             String
  label            String?
  description      String   @default("")
  type             String   @default("string")
  required         Boolean  @default(false)
  defaultValueJson String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  endpoint         Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([endpointId, position])
  @@unique([endpointId, name])
  @@index([endpointId])
}

model ResponseCase {
  id              String   @id
  endpointId      String
  name            String
  priority        Int      @default(0)
  matchArgsJson   String   @default("{}")
  responseJson    String
  statusCode      Int      @default(200)
  delayMs         Int      @default(0)
  errorMode       String   @default("none")
  errorStatusCode Int?
  errorMessage    String?
  errorBodyJson   String?
  isDefault       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  endpoint        Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@unique([endpointId, name])
  @@index([endpointId, priority])
  @@index([endpointId])
}

model AuditEvent {
  id           String   @id
  eventType    String
  subjectType  String
  subjectId    String?
  subjectName  String?
  outcome      String
  actorType    String   @default("public")
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  @@index([eventType, createdAt])
  @@index([subjectType, subjectId])
}

model ServerSetting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model BasicUser {
  id           String   @id
  username     String   @unique
  passwordHash String
  enabled      Boolean  @default(true)
  builtIn      Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([builtIn, username])
}

model OAuthUser {
  id                    String                   @id
  username              String                   @unique
  passwordHash          String
  enabled               Boolean                  @default(true)
  builtIn               Boolean                  @default(false)
  accessTokenTtlSeconds Int                      @default(3600)
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  authorizationCodes    OAuthAuthorizationCode[]
  issuedTokens          OAuthIssuedToken[]

  @@index([builtIn, username])
}

model OAuthClient {
  id                          String                       @id
  clientId                    String                       @unique
  displayName                 String                       @default("")
  secretHash                  String
  enabled                     Boolean                      @default(true)
  builtIn                     Boolean                      @default(false)
  redirectUrisJson            String                       @default("[]")
  clientCredentialsTtlSeconds Int                          @default(3600)
  createdAt                   DateTime                     @default(now())
  updatedAt                   DateTime                     @updatedAt
  allowedEndpoints            OAuthClientAllowedEndpoint[]
  allowedResources            OAuthClientAllowedResource[]
  allowedResourceTemplates     OAuthClientAllowedResourceTemplate[]
  allowedPrompts              OAuthClientAllowedPrompt[]
  authorizationCodes          OAuthAuthorizationCode[]
  issuedTokens                OAuthIssuedToken[]

  @@index([builtIn, clientId])
}

model OAuthClientAllowedEndpoint {
  oauthClientId String
  endpointId    String
  createdAt     DateTime    @default(now())
  oauthClient   OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)
  endpoint      Endpoint    @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@id([oauthClientId, endpointId])
  @@index([endpointId])
}

model OAuthClientAllowedResource {
  oauthClientId String
  resourceId    String
  createdAt     DateTime    @default(now())
  oauthClient   OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)
  resource      McpResource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([oauthClientId, resourceId])
  @@index([resourceId])
}

model OAuthClientAllowedResourceTemplate {
  oauthClientId      String
  resourceTemplateId String
  createdAt          DateTime            @default(now())
  oauthClient        OAuthClient         @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)
  resourceTemplate   McpResourceTemplate @relation(fields: [resourceTemplateId], references: [id], onDelete: Cascade)

  @@id([oauthClientId, resourceTemplateId])
  @@index([resourceTemplateId])
}

model OAuthClientAllowedPrompt {
  oauthClientId String
  promptId      String
  createdAt     DateTime    @default(now())
  oauthClient   OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)
  prompt        McpPrompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@id([oauthClientId, promptId])
  @@index([promptId])
}

model OAuthAuthorizationCode {
  id                  String                           @id
  code                String                           @unique
  oauthClientId       String
  oauthUserId         String
  redirectUri         String
  resource            String
  state               String?
  codeChallenge       String?
  codeChallengeMethod String?
  expiresAt           DateTime
  usedAt              DateTime?
  createdAt           DateTime                         @default(now())
  oauthClient         OAuthClient                      @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)
  oauthUser           OAuthUser                        @relation(fields: [oauthUserId], references: [id], onDelete: Cascade)
  selectedEndpoints   OAuthAuthorizationCodeEndpoint[]
  selectedResources   OAuthAuthorizationCodeResource[]
  selectedResourceTemplates OAuthAuthorizationCodeResourceTemplate[]
  selectedPrompts     OAuthAuthorizationCodePrompt[]

  @@index([code])
  @@index([oauthClientId, oauthUserId])
  @@index([expiresAt])
}

model OAuthAuthorizationCodeEndpoint {
  authorizationCodeId String
  endpointId          String
  createdAt           DateTime               @default(now())
  authorizationCode   OAuthAuthorizationCode @relation(fields: [authorizationCodeId], references: [id], onDelete: Cascade)
  endpoint            Endpoint               @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@id([authorizationCodeId, endpointId])
  @@index([endpointId])
}

model OAuthAuthorizationCodeResource {
  authorizationCodeId String
  resourceId          String
  createdAt           DateTime               @default(now())
  authorizationCode   OAuthAuthorizationCode @relation(fields: [authorizationCodeId], references: [id], onDelete: Cascade)
  resource            McpResource            @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@id([authorizationCodeId, resourceId])
  @@index([resourceId])
}

model OAuthAuthorizationCodeResourceTemplate {
  authorizationCodeId String
  resourceTemplateId  String
  createdAt           DateTime               @default(now())
  authorizationCode   OAuthAuthorizationCode @relation(fields: [authorizationCodeId], references: [id], onDelete: Cascade)
  resourceTemplate    McpResourceTemplate    @relation(fields: [resourceTemplateId], references: [id], onDelete: Cascade)

  @@id([authorizationCodeId, resourceTemplateId])
  @@index([resourceTemplateId])
}

model OAuthAuthorizationCodePrompt {
  authorizationCodeId String
  promptId            String
  createdAt           DateTime               @default(now())
  authorizationCode   OAuthAuthorizationCode @relation(fields: [authorizationCodeId], references: [id], onDelete: Cascade)
  prompt              McpPrompt              @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@id([authorizationCodeId, promptId])
  @@index([promptId])
}

model OAuthIssuedToken {
  id                      String      @id
  jti                     String      @unique
  oauthClientId           String
  oauthUserId             String?
  grantType               String
  scope                   String
  issuer                  String      @default("http://localhost:3000")
  resource                String
  endpointPermissionsJson String      @default("[]")
  resourcePermissionsJson String      @default("[]")
  resourceTemplatePermissionsJson String @default("[]")
  promptPermissionsJson   String      @default("[]")
  issuedAt                DateTime
  expiresAt               DateTime
  revokedAt               DateTime?
  createdAt               DateTime    @default(now())
  oauthClient             OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)
  oauthUser               OAuthUser?  @relation(fields: [oauthUserId], references: [id], onDelete: Cascade)

  @@index([jti])
  @@index([oauthClientId, oauthUserId])
  @@index([expiresAt])
  @@index([revokedAt])
}

model McpResource {
  id                String   @id
  uri               String   @unique
  name              String
  title             String   @default("")
  description       String   @default("")
  mimeType          String
  enabled           Boolean  @default(true)
  protectedDefault  Boolean  @default(false)
  textContent       String?
  blobContentBase64 String?
  annotationsJson   String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  oauthClientAllowances OAuthClientAllowedResource[]
  oauthCodePermissions  OAuthAuthorizationCodeResource[]

  @@index([enabled, uri])
}

model McpResourceTemplate {
  id                   String                        @id
  uriTemplate          String                        @unique
  name                 String                        @unique
  title                String                        @default("")
  description          String                        @default("")
  mimeType             String
  enabled              Boolean                       @default(true)
  protectedDefault     Boolean                       @default(false)
  textTemplate         String?
  blobTemplateBase64   String?
  annotationsJson      String?
  createdAt            DateTime                      @default(now())
  updatedAt            DateTime                      @updatedAt
  arguments            McpResourceTemplateArgument[]
  completionCandidates McpCompletionCandidate[]
  oauthClientAllowances OAuthClientAllowedResourceTemplate[]
  oauthCodePermissions  OAuthAuthorizationCodeResourceTemplate[]

  @@index([enabled, name])
}

model McpResourceTemplateArgument {
  id                 String              @id
  resourceTemplateId String
  position           Int
  name               String
  description        String              @default("")
  required           Boolean             @default(true)
  sampleValueJson    String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  resourceTemplate   McpResourceTemplate @relation(fields: [resourceTemplateId], references: [id], onDelete: Cascade)

  @@unique([resourceTemplateId, position])
  @@unique([resourceTemplateId, name])
  @@index([resourceTemplateId])
}

model McpPrompt {
  id                   String                   @id
  name                 String                   @unique
  title                String                   @default("")
  description          String                   @default("")
  enabled              Boolean                  @default(true)
  protectedDefault     Boolean                  @default(false)
  createdAt            DateTime                 @default(now())
  updatedAt            DateTime                 @updatedAt
  arguments            McpPromptArgument[]
  messages             McpPromptMessage[]
  completionCandidates McpCompletionCandidate[]
  oauthClientAllowances OAuthClientAllowedPrompt[]
  oauthCodePermissions  OAuthAuthorizationCodePrompt[]

  @@index([enabled, name])
}

model McpPromptArgument {
  id          String    @id
  promptId    String
  position    Int
  name        String
  title       String    @default("")
  description String    @default("")
  required    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  prompt      McpPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, position])
  @@unique([promptId, name])
  @@index([promptId])
}

model McpPromptMessage {
  id               String    @id
  promptId         String
  position         Int
  role             String
  textTemplate     String?
  resourceUri      String?
  resourceMimeType String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  prompt           McpPrompt @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([promptId, position])
  @@index([promptId])
}

model McpCompletionCandidate {
  id                 String               @id
  ownerType          String
  resourceTemplateId String?
  promptId           String?
  argumentName       String
  value              String
  label              String               @default("")
  position           Int                  @default(0)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  resourceTemplate   McpResourceTemplate? @relation(fields: [resourceTemplateId], references: [id], onDelete: Cascade)
  prompt             McpPrompt?           @relation(fields: [promptId], references: [id], onDelete: Cascade)

  @@unique([resourceTemplateId, argumentName, value])
  @@unique([promptId, argumentName, value])
  @@index([ownerType, argumentName])
  @@index([resourceTemplateId])
  @@index([promptId])
}
