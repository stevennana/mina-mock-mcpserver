ic-auth/service.ts:168:  const verified = await verifyBasicPassword(password, user.passwordHash);\n./lib/mcp/http.ts:2:import { resolveBasicAuthorizationHeader } from \"@/lib/auth/basic\";\n./lib/mcp/http.ts:8:function unauthorizedBasicResponse(message = \"Valid Basic credentials are required.\") {\n./lib/mcp/http.ts:17:        \"WWW-Authenticate\": 'Basic realm=\"MCP Mock Server\"',\n./lib/mcp/http.ts:52:  const resolution = await resolveBasicAuthorizationHeader(authorization);\n./lib/mcp/http.ts:55:    return unauthorizedBasicResponse(\"Authorization header was invalid.\");\n./lib/mcp/http.ts:61:  return unauthorizedBasicResponse();\n./lib/mcp/http.ts:64:export async function handleStrictBasicMcpPost(request: Request) {\n./lib/mcp/http.ts:65:  const resolution = await resolveBasicAuthorizationHeader(request.headers.get(\"Authorization\"));\n./lib/mcp/http.ts:67:    return unauthorizedBasicResponse();\n./lib/reset/types.ts:11:  deletedBasicUsers: number;\n./lib/reset/types.ts:12:  seededBasicUsers: number;\n./lib/reset/service.ts:45:    const deletedBasicUsers = await tx.basicUser.deleteMany({});\n./lib/reset/service.ts:52:    const seededBasicUsers = await tx.basicUser.count();\n./lib/reset/service.ts:64:          deletedBasicUsers: deletedBasicUsers.count,\n./lib/reset/service.ts:66:          seededBasicUsers,\n./lib/reset/service.ts:75:      deletedBasicUsers: deletedBasicUsers.count,\n./lib/reset/service.ts:76:      seededBasicUsers,\n./lib/basic-auth/types.ts:5:export type BasicUserSummary = {\n./lib/basic-auth/types.ts:9:  builtIn: boolean;\n./lib/basic-auth/types.ts:14:export type BasicUserListResult = {\n./lib/basic-auth/types.ts:18:  users: BasicUserSummary[];\n./lib/basic-auth/types.ts:21:export type BasicUserCreateInput = {\n./lib/basic-auth/types.ts:27:export type BasicUserUpdateInput = {\n./lib/basic-auth/types.ts:32:export class BasicUserValidationError extends Error {\n./lib/basic-auth/types.ts:34:    super(\"Basic user validation failed.\");\n./lib/basic-auth/types.ts:38:export class BasicUserBuiltInError extends Error {\n./lib/basic-auth/types.ts:40:    super(\"Built-in Basic user cannot be changed.\");\n./lib/basic-auth/types.ts:44:export class BasicUserNotFoundError extends Error {\n./lib/basic-auth/types.ts:46:    super(\"Basic user not found.\");\n./PRD/mcp_mock_server_prd.md:2:## Remote MCP Mock Server with Public Web UI, Multi-Auth Testing, OAuth Permission Selection\n./PRD/mcp_mock_server_prd.md:18:2. **HTTP Basic authentication**\n./PRD/mcp_mock_server_prd.md:19:3. **Mock OAuth2/OAuth 2.1-style authentication with JWT access tokens**\n./PRD/mcp_mock_server_prd.md:25:The product is not intended to be a secure production authorization service. It is a realistic, configurable, public mock server for testing MCP client behavior, authentication handling, token handling, endpoint-level OAuth permissions, and failure scenarios.\n./PRD/mcp_mock_server_prd.md:37:The OAuth design should be inspired by the Atlassian Rovo MCP Server pattern: the MCP client initiates an OAuth flow, the user completes an interactive browser-based consent flow, the client receives an access token, and subsequent MCP requests include `Authorization: Bearer <access_token>`. Atlassian also documents Basic-style API token authentication as a non-interactive alternative, which maps well to this mock server’s Basic Auth test mode. ([support.atlassian.com](https://support.atlassian.com/atlassian-rovo-mcp-server/docs/authentication-and-authorization/))\n./PRD/mcp_mock_server_prd.md:39:For MCP authorization, the product should expose OAuth-style discovery metadata where feasible. The MCP authorization specification describes MCP servers as OAuth resource servers, recommends authorization-server discovery, and requires bearer tokens to be sent in the `Authorization` header for protected requests. It also defines `401 Unauthorized` for missing or invalid authorization and `403 Forbidden` for insufficient permissions/scopes. ([modelcontextprotocol.io](https://modelcontextprotocol.io/specification/2025-11-25/basic/authorization))\n./PRD/mcp_mock_server_prd.md:58:   - HTTP Basic authentication\n./PRD/mcp_mock_server_prd.md:59:   - OAuth-style JWT bearer authentication\n./PRD/mcp_mock_server_prd.md:60:7. Use a mock OAuth login and consent flow without relying on an external OAuth service.\n./PRD/mcp_mock_server_prd.md:61:8. Select endpoint-level permissions during OAuth consent.\n./PRD/mcp_mock_server_prd.md:62:9. Ensure OAuth-issued tokens can only call the endpoints selected during consent.\n./PRD/mcp_mock_server_prd.md:63:10. Manage issued OAuth tokens through the Web UI, including viewing token claims/permissions and revoking tokens.\n./PRD/mcp_mock_server_prd.md:75:2. Integrate with external OAuth providers.\n./PRD/mcp_mock_server_prd.md:149:2. **Basic**\n./PRD/mcp_mock_server_prd.md:150:   - Uses `Authorization: Basic <base64(username:password)>`.\n./PRD/mcp_mock_server_prd.md:152:   - Built-in `default/default` user must always work and cannot be deleted.\n./PRD/mcp_mock_server_prd.md:154:3. **OAuth Bearer**\n./PRD/mcp_mock_server_prd.md:156:   - Token is issued by the mock OAuth flow.\n./PRD/mcp_mock_server_prd.md:159:   - Built-in OAuth user `default/default` must always work and cannot be deleted.\n./PRD/mcp_mock_server_prd.md:160:   - Built-in OAuth client `default/default` must always work and cannot be deleted.\n./PRD/mcp_mock_server_prd.md:168:| `/mcp` | Accepts None, Basic, or OAuth. Auth method is inferred from request headers. |\n./PRD/mcp_mock_server_prd.md:170:| `/mcp/basic` | Requires valid Basic Auth. Missing/invalid Basic Auth returns `401`. |\n./PRD/mcp_mock_server_prd.md:173:This avoids ambiguity during tests. For example, an MCP client that claims to be testing OAuth can be pointed to `/mcp/oauth`, while a client testing no-auth can be pointed to `/mcp/none`.\n./PRD/mcp_mock_server_prd.md:248:   - easy raw HTTP control for MCP and OAuth responses\n./PRD/mcp_mock_server_prd.md:312:The endpoint `name` should be editable only if no issued OAuth token currently references the endpoint by name. To avoid permission drift, the system should internally use immutable endpoint IDs and expose names separately.\n./PRD/mcp_mock_server_prd.md:324:- OAuth client allowed-endpoint mappings are cleaned up\n./PRD/mcp_mock_server_prd.md:336:- Must not break built-in `default/default` Basic user.\n./PRD/mcp_mock_server_prd.md:337:- Must not break built-in `default/default` OAuth user.\n./PRD/mcp_mock_server_prd.md:338:- Must not break built-in `default/default` OAuth client.\n./PRD/mcp_mock_server_prd.md:426:### FR-AUTH-002: Basic Auth Mode\n./PRD/mcp_mock_server_prd.md:428:The server must support HTTP Basic Auth.\n./PRD/mcp_mock_server_prd.md:433:Authorization: Basic base64(username:password)\n./PRD/mcp_mock_server_prd.md:438:- `default/default` must always work.\n./PRD/mcp_mock_server_prd.md:439:- `default/default` cannot be deleted.\n./PRD/mcp_mock_server_prd.md:440:- `default/default` password cannot be changed.\n./PRD/mcp_mock_server_prd.md:441:- Additional Basic Auth users can be created, edited, disabled, and deleted from the Web UI.\n./PRD/mcp_mock_server_prd.md:443:- If an invalid Basic header is sent, the server must return `401`.\n./PRD/mcp_mock_server_prd.md:444:- Successful Basic Auth gives access to all enabled endpoints.\n./PRD/mcp_mock_server_prd.md:446:### FR-AUTH-003: OAuth Bearer Mode\n./PRD/mcp_mock_server_prd.md:448:The server must support mock OAuth-style bearer authentication.\n./PRD/mcp_mock_server_prd.md:466:- OAuth token permissions apply only to OAuth Bearer mode.\n./PRD/mcp_mock_server_prd.md:467:- OAuth token permissions do not apply to None or Basic mode.\n./PRD/mcp_mock_server_prd.md:474:2. If `Authorization` starts with `Basic`, validate Basic.\n./PRD/mcp_mock_server_prd.md:475:3. If `Authorization` starts with `Bearer`, validate OAuth token.\n./PRD/mcp_mock_server_prd.md:477:5. Do not silently downgrade invalid Basic or Bearer requests to None mode.\n./PRD/mcp_mock_server_prd.md:483:- missing Basic Auth returns `401`\n./PRD/mcp_mock_server_prd.md:484:- invalid Basic Auth returns `401`\n./PRD/mcp_mock_server_prd.md:485:- valid Basic Auth gives access to all enabled endpoints\n./PRD/mcp_mock_server_prd.md:496:## 8.3 OAuth Mock Requirements\n./PRD/mcp_mock_server_prd.md:498:### FR-OAUTH-001: Built-in OAuth User\n./PRD/mcp_mock_server_prd.md:514:### FR-OAUTH-002: OAuth User Management\n./PRD/mcp_mock_server_prd.md:516:The Web UI must allow public users to manage OAuth login users.\n./PRD/mcp_mock_server_prd.md:524:| `tokenTtlSeconds` | Access token lifetime for this user. |\n./PRD/mcp_mock_server_prd.md:528:### FR-OAUTH-003: Built-in OAuth Client\n./PRD/mcp_mock_server_prd.md:545:### FR-OAUTH-004: OAuth Client Management\n./PRD/mcp_mock_server_prd.md:547:The Web UI must allow public users to create and manage OAuth clients.\n./PRD/mcp_mock_server_prd.md:578:  -> Mock OAuth login UI\n./PRD/mcp_mock_server_prd.md:593:| `client_id` | yes | Registered OAuth client ID. |\n./PRD/mcp_mock_server_prd.md:629:- User may select any endpoint allowed by the OAuth client.\n./PRD/mcp_mock_server_prd.md:695:- Token TTL comes from the OAuth client’s `clientCredentialsTtlSeconds`.\n./PRD/mcp_mock_server_prd.md:731:- verify endpoint permission for OAuth calls\n./PRD/mcp_mock_server_prd.md:733:### FR-OAUTH-010: OAuth Discovery Metadata\n./PRD/mcp_mock_server_prd.md:735:The server should expose mock OAuth discovery endpoints:\n./PRD/mcp_mock_server_prd.md:782:- On every OAuth request, validate that the token `jti` is not revoked.\n./PRD/mcp_mock_server_prd.md:894:No-auth and Basic response:\n./PRD/mcp_mock_server_prd.md:898:OAuth response:\n./PRD/mcp_mock_server_prd.md:1006:### FR-MCP-008: OAuth Permission Denial\n./PRD/mcp_mock_server_prd.md:1008:If a valid OAuth token calls a tool not included in its endpoint permission set:\n./PRD/mcp_mock_server_prd.md:1032:### FR-MCP-009: Invalid or Expired OAuth Token\n./PRD/mcp