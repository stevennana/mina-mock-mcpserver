{"type":"item.completed","item":{"id":"item_32","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' app/page.tsx && sed -n '1,260p' app/globals.css\"","aggregated_output":"import { getBootstrapStatus } from \"@/lib/bootstrap-status\";\nimport { listEndpoints } from \"@/lib/endpoints/service\";\nimport Link from \"next/link\";\n\nconst plannedSurfaces = [\n  \"Endpoint and tool management\",\n  \"MCP JSON-RPC runtime\",\n  \"REST mock API\",\n  \"Basic Auth management\",\n  \"OAuth consent and token runtime\",\n  \"Failure simulation and audit\",\n  \"Operator configuration and startup proof\",\n];\n\nexport default async function Home() {\n  const status = getBootstrapStatus();\n  const endpointData = await listEndpoints();\n\n  return (\n    <main className=\"shell app-shell\">\n      <nav className=\"top-nav\" aria-label=\"Primary\">\n        <Link href=\"/\" aria-current=\"page\">Dashboard</Link>\n        <Link href=\"/endpoints\">Endpoints</Link>\n        <Link href=\"/basic-users\">Basic Users</Link>\n        <Link href=\"/oauth-users\">OAuth Users</Link>\n        <Link href=\"/oauth-clients\">OAuth Clients</Link>\n        <Link href=\"/tokens\">Tokens</Link>\n        <Link href=\"/config\">Config</Link>\n        <Link href=\"/reset\">Reset</Link>\n        <Link href=\"/audit\">Audit</Link>\n      </nav>\n      <section className=\"hero\" aria-labelledby=\"page-title\">\n        <p className=\"eyebrow\">Public test bench</p>\n        <h1 id=\"page-title\">MCP Mock Server</h1>\n        <p className=\"lede\">\n          Public remote MCP mock server for testing no-auth, Basic Auth, mock OAuth bearer tokens,\n          endpoint permissions, and tool-call failure modes.\n        </p>\n        <p className=\"lede compact\">\n          Use the <Link href=\"/config\">connection guide</Link> for MCP, OAuth discovery metadata, and JWKS URLs.\n        </p>\n      </section>\n\n      <section className=\"status-grid\" aria-label=\"Bootstrap status\">\n        <div>\n          <span>Runtime state</span>\n          <strong>{status.runtimeState}</strong>\n        </div>\n        <div>\n          <span>Log level</span>\n          <strong>{status.logLevel}</strong>\n        </div>\n        <div>\n          <span>Health route</span>\n          <strong>/api/health</strong>\n        </div>\n        <div>\n          <span>Persisted endpoints</span>\n          <strong>{endpointData.total}</strong>\n        </div>\n        <div>\n          <span>Enabled tools</span>\n          <strong>{endpointData.enabled}</strong>\n        </div>\n        <div>\n          <span>Disabled tools</span>\n          <strong>{endpointData.disabled}</strong>\n        </div>\n      </section>\n\n      <section className=\"panel\" aria-labelledby=\"queue-title\">\n        <h2 id=\"queue-title\">Queued feature fronts</h2>\n        <ul>\n          {plannedSurfaces.map((surface) => (\n            <li key={surface}>{surface}</li>\n          ))}\n        </ul>\n      </section>\n    </main>\n  );\n}\n:root {\n  color-scheme: light;\n  --bg: #f7f8fa;\n  --fg: #171a1f;\n  --muted: #5c6675;\n  --line: #d9dee7;\n  --panel: #ffffff;\n  --accent: #0d766e;\n}\n\n* {\n  box-sizing: border-box;\n}\n\nhtml,\nbody {\n  min-height: 100%;\n  margin: 0;\n}\n\nbody {\n  background: var(--bg);\n  color: var(--fg);\n  font-family: \"Aptos\", \"Segoe UI\", Helvetica, Arial, sans-serif;\n}\n\na {\n  color: inherit;\n}\n\nbutton,\ninput,\nselect,\ntextarea {\n  font: inherit;\n}\n\n.shell {\n  width: min(1120px, calc(100% - 32px));\n  margin: 0 auto;\n  padding: 48px 0;\n}\n\n.app-shell {\n  padding-top: 24px;\n}\n\n.top-nav {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 8px;\n  margin-bottom: 28px;\n}\n\n.top-nav a {\n  min-height: 44px;\n  display: inline-flex;\n  align-items: center;\n  border: 1px solid var(--line);\n  border-radius: 8px;\n  padding: 0 14px;\n  background: var(--panel);\n  color: var(--muted);\n  font-size: 0.92rem;\n  font-weight: 700;\n  text-decoration: none;\n}\n\n.top-nav a[aria-current=\"page\"] {\n  border-color: #8ac8c0;\n  color: #084d48;\n}\n\n.hero {\n  padding: 24px 0 28px;\n}\n\n.eyebrow {\n  margin: 0 0 10px;\n  color: var(--accent);\n  font-size: 0.78rem;\n  font-weight: 700;\n  text-transform: uppercase;\n}\n\nh1 {\n  max-width: 780px;\n  margin: 0;\n  font-size: clamp(2.4rem, 6vw, 4.8rem);\n  line-height: 1;\n  letter-spacing: 0;\n}\n\n.lede {\n  max-width: 720px;\n  margin: 18px 0 0;\n  color: var(--muted);\n  font-size: 1.1rem;\n  line-height: 1.6;\n}\n\n.status-grid {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 12px;\n  margin: 8px 0 28px;\n}\n\n.status-grid > div,\n.panel {\n  border: 1px solid var(--line);\n  border-radius: 8px;\n  background: var(--panel);\n}\n\n.status-grid > div {\n  min-height: 92px;\n  padding: 18px;\n}\n\n.status-grid span {\n  display: block;\n  color: var(--muted);\n  font-size: 0.86rem;\n}\n\n.status-grid strong {\n  display: block;\n  margin-top: 8px;\n  font-size: 1.2rem;\n}\n\n.panel {\n  padding: 22px;\n}\n\n.panel h2 {\n  margin: 0 0 16px;\n  font-size: 1.2rem;\n}\n\n.panel ul {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 10px 24px;\n  margin: 0;\n  padding-left: 20px;\n  color: var(--muted);\n}\n\n.page-header {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr);\n  gap: 18px;\n  margin-bottom: 24px;\n}\n\n.page-header h1 {\n  font-size: 2.35rem;\n}\n\n.lede.compact {\n  max-width: 760px;\n  font-size: 1rem;\n}\n\n.summary-strip {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 8px;\n}\n\n.summary-strip span {\n  min-height: 64px;\n  border: 1px solid var(--line);\n  border-radius: 8px;\n  padding: 12px;\n  background: var(--panel);\n  color: var(--muted);\n  font-size: 0.82rem;\n  font-weight: 700;\n  text-transform: uppercase;\n}\n\n.summary-strip strong {\n  display: block;\n  color: var(--fg);\n  font-size: 1.35rem;\n}\n\n.endpoint-layout {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 16px;\n  align-items: start;\n}\n\n.endpoint-list-panel,\n.endpoint-editor-panel,\n.editor-section {\n  border: 1px solid var(--line);\n  border-radius: 8px;\n  background: var(--panel);\n}\n\n.endpoint-list-panel,\n.endpoint-editor-panel {\n  min-width: 0;\n  padding: 16px;\n}\n\n.section-heading-row {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  align-items: flex-start;\n  justify-content: space-between;\n  margin-bottom: 14px;\n}\n\n.section-heading-row h2,\n.editor-section h3 {\n  margin: 0;\n  font-size: 1.05rem;\n}\n\n.section-heading-row p {\n  margin: 4px 0 0;\n  color: var(--muted);\n  font-size: 0.9rem;\n}\n\n.primary-button,\n.secondary-button,\n.danger-button {\n  min-height: 44px;\n  border: 1px solid transparent;\n  border-radius: 8px;\n  padding: 0 14px;\n  font-weight: 800;\n  cursor: pointer;\n}\n\n.primary-button {\n  background: var(--accent);\n  color: #ffffff;\n}\n\n.secondary-button {\n  border-color: var(--line);\n  background: #f8fafc;\n  color: #26313f;\n}\n\n.danger-button {\n  background: #b42318;\n  color: #ffffff;\n}\n\n.primary-button:disabled,\n","exit_code":0,"status":"completed"}}
