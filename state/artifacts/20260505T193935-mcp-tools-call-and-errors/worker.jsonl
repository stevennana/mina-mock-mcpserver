{"type":"item.completed","item":{"id":"item_32","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' lib/db/seed.ts\"","aggregated_output":"import type { PrismaClient } from \"@prisma/client\";\n\nexport const DEFAULT_ENDPOINT_ID = \"endpoint_default_echo\";\n\ntype SeedClient = Pick<PrismaClient, \"endpoint\" | \"endpointParam\" | \"responseCase\">;\n\nexport async function seedEndpointDefaults(client: SeedClient) {\n  await client.endpoint.upsert({\n    where: { id: DEFAULT_ENDPOINT_ID },\n    update: {\n      name: \"echo\",\n      title: \"Echo\",\n      description: \"Default enabled endpoint for smoke-testing endpoint persistence.\",\n      enabled: true,\n      protectedDefault: true,\n      deleteCode: \"12345678\",\n      defaultResponseJson: JSON.stringify({ ok: true, source: \"default\" }),\n      failureMode: \"none\",\n      failureStatusCode: null,\n      failureDelayMs: 0,\n      failureMessage: null,\n      malformedResponseJson: null,\n    },\n    create: {\n      id: DEFAULT_ENDPOINT_ID,\n      name: \"echo\",\n      title: \"Echo\",\n      description: \"Default enabled endpoint for smoke-testing endpoint persistence.\",\n      enabled: true,\n      protectedDefault: true,\n      deleteCode: \"12345678\",\n      defaultResponseJson: JSON.stringify({ ok: true, source: \"default\" }),\n      parameters: {\n        create: [\n          {\n            id: `${DEFAULT_ENDPOINT_ID}_param_message`,\n            position: 0,\n            name: \"message\",\n            label: \"Message\",\n            description: \"Message to echo back in later runtime slices.\",\n            type: \"string\",\n            required: true,\n          },\n        ],\n      },\n      responseCases: {\n        create: [\n          {\n            id: `${DEFAULT_ENDPOINT_ID}_case_default`,\n            name: \"default\",\n            priority: 0,\n            matchArgsJson: \"{}\",\n            responseJson: JSON.stringify({ ok: true, source: \"default\" }),\n            statusCode: 200,\n            delayMs: 0,\n            errorMode: \"none\",\n            isDefault: true,\n          },\n          {\n            id: `${DEFAULT_ENDPOINT_ID}_case_hello`,\n            name: \"hello-world\",\n            priority: 10,\n            matchArgsJson: JSON.stringify({ message: \"hello\" }),\n            responseJson: JSON.stringify({ ok: true, message: \"world\" }),\n            statusCode: 200,\n            delayMs: 0,\n            errorMode: \"none\",\n            isDefault: false,\n          },\n        ],\n      },\n    },\n  });\n\n  await client.endpointParam.upsert({\n    where: {\n      endpointId_name: {\n        endpointId: DEFAULT_ENDPOINT_ID,\n        name: \"message\",\n      },\n    },\n    update: {\n      position: 0,\n      label: \"Message\",\n      description: \"Message to echo back in later runtime slices.\",\n      type: \"string\",\n      required: true,\n      defaultValueJson: null,\n    },\n    create: {\n      id: `${DEFAULT_ENDPOINT_ID}_param_message`,\n      endpointId: DEFAULT_ENDPOINT_ID,\n      position: 0,\n      name: \"message\",\n      label: \"Message\",\n      description: \"Message to echo back in later runtime slices.\",\n      type: \"string\",\n      required: true,\n    },\n  });\n\n  await client.responseCase.upsert({\n    where: {\n      endpointId_name: {\n        endpointId: DEFAULT_ENDPOINT_ID,\n        name: \"default\",\n      },\n    },\n    update: {\n      priority: 0,\n      matchArgsJson: \"{}\",\n      responseJson: JSON.stringify({ ok: true, source: \"default\" }),\n      statusCode: 200,\n      delayMs: 0,\n      errorMode: \"none\",\n      errorStatusCode: null,\n      errorMessage: null,\n      errorBodyJson: null,\n      isDefault: true,\n    },\n    create: {\n      id: `${DEFAULT_ENDPOINT_ID}_case_default`,\n      endpointId: DEFAULT_ENDPOINT_ID,\n      name: \"default\",\n      priority: 0,\n      matchArgsJson: \"{}\",\n      responseJson: JSON.stringify({ ok: true, source: \"default\" }),\n      statusCode: 200,\n      delayMs: 0,\n      errorMode: \"none\",\n      isDefault: true,\n    },\n  });\n\n  await client.responseCase.upsert({\n    where: {\n      endpointId_name: {\n        endpointId: DEFAULT_ENDPOINT_ID,\n        name: \"hello-world\",\n      },\n    },\n    update: {\n      priority: 10,\n      matchArgsJson: JSON.stringify({ message: \"hello\" }),\n      responseJson: JSON.stringify({ ok: true, message: \"world\" }),\n      statusCode: 200,\n      delayMs: 0,\n      errorMode: \"none\",\n      errorStatusCode: null,\n      errorMessage: null,\n      errorBodyJson: null,\n      isDefault: false,\n    },\n    create: {\n      id: `${DEFAULT_ENDPOINT_ID}_case_hello`,\n      endpointId: DEFAULT_ENDPOINT_ID,\n      name: \"hello-world\",\n      priority: 10,\n      matchArgsJson: JSON.stringify({ message: \"hello\" }),\n      responseJson: JSON.stringify({ ok: true, message: \"world\" }),\n      statusCode: 200,\n      delayMs: 0,\n      errorMode: \"none\",\n      isDefault: false,\n    },\n  });\n}\n","exit_code":0,"status":"completed"}}
{"type":"item.completed","item":{"id":"item_33","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,320p' prisma/schema.prisma\"","aggregated_output":"generator client {\n  provider = \"prisma-client-js\"\n}\n\ndatasource db {\n  provider = \"sqlite\"\n}\n\nmodel Endpoint {\n  id                    String          @id\n  name                  String          @unique\n  title                 String          @default(\"\")\n  description           String          @default(\"\")\n  enabled               Boolean         @default(true)\n  protectedDefault      Boolean         @default(false)\n  deleteCode            String?\n  defaultResponseJson   String          @default(\"{}\")\n  failureMode           String          @default(\"none\")\n  failureStatusCode     Int?\n  failureDelayMs        Int             @default(0)\n  failureMessage        String?\n  malformedResponseJson String?\n  createdAt             DateTime        @default(now())\n  updatedAt             DateTime        @updatedAt\n  parameters            EndpointParam[]\n  responseCases         ResponseCase[]\n}\n\nmodel EndpointParam {\n  id               String   @id\n  endpointId       String\n  position         Int\n  name             String\n  label            String?\n  description      String   @default(\"\")\n  type             String   @default(\"string\")\n  required         Boolean  @default(false)\n  defaultValueJson String?\n  createdAt        DateTime @default(now())\n  updatedAt        DateTime @updatedAt\n  endpoint         Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n\n  @@unique([endpointId, position])\n  @@unique([endpointId, name])\n  @@index([endpointId])\n}\n\nmodel ResponseCase {\n  id              String   @id\n  endpointId      String\n  name            String\n  priority        Int      @default(0)\n  matchArgsJson   String   @default(\"{}\")\n  responseJson    String\n  statusCode      Int      @default(200)\n  delayMs         Int      @default(0)\n  errorMode       String   @default(\"none\")\n  errorStatusCode Int?\n  errorMessage    String?\n  errorBodyJson   String?\n  isDefault       Boolean  @default(false)\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n  endpoint        Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n\n  @@unique([endpointId, name])\n  @@index([endpointId, priority])\n  @@index([endpointId])\n}\n\nmodel AuditEvent {\n  id             String   @id\n  eventType      String\n  subjectType    String\n  subjectId      String?\n  subjectName    String?\n  outcome        String\n  actorType      String   @default(\"public\")\n  metadataJson   String   @default(\"{}\")\n  createdAt      DateTime @default(now())\n\n  @@index([eventType, createdAt])\n  @@index([subjectType, subjectId])\n}\n","exit_code":0,"status":"completed"}}
