          id: `${id}_param_${position}_${randomUUID()}`,
          position,
          name: parameter.name,
          label: parameter.label || null,
          description: parameter.description ?? "",
          type: parameter.type,
          required: parameter.required,
          defaultValueJson: parameter.defaultValueJson,
        })),
      },
      responseCases: {
