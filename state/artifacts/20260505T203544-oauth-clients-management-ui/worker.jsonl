{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' app/oauth-users/page.tsx && sed -n '1,120p' app/page.tsx && sed -n '1,120p' app/layout.tsx\"","aggregated_output":"import Link from \"next/link\";\nimport { OAuthUsersManager } from \"@/app/oauth-users/oauth-users-manager\";\nimport { listOAuthUsers } from \"@/lib/oauth/service\";\n\nexport default async function OAuthUsersPage() {\n  const userData = await listOAuthUsers();\n\n  return (\n    <main className=\"shell app-shell\">\n      <nav className=\"top-nav\" aria-label=\"Primary\">\n        <Link href=\"/\">Dashboard</Link>\n        <Link href=\"/endpoints\">Endpoints</Link>\n        <Link href=\"/basic-users\">Basic Users</Link>\n        <Link href=\"/oauth-users\" aria-current=\"page\">OAuth Users</Link>\n        <Link href=\"/reset\">Reset</Link>\n        <Link href=\"/audit\">Audit</Link>\n      </nav>\n      <header className=\"page-header\">\n        <div>\n          <p className=\"eyebrow\">OAuth login identities</p>\n          <h1>OAuth users</h1>\n          <p className=\"lede compact\">\n            Manage public login fixtures and token TTL presets for the mock OAuth authorization-code runtime.\n          </p>\n        </div>\n        <div className=\"summary-strip\" aria-label=\"OAuth user counts\">\n          <span><strong>{userData.total}</strong>Total</span>\n          <span><strong>{userData.enabled}</strong>Enabled</span>\n          <span><strong>{userData.disabled}</strong>Disabled</span>\n        </div>\n      </header>\n      <OAuthUsersManager initialData={userData} />\n    </main>\n  );\n}\nimport { getBootstrapStatus } from \"@/lib/bootstrap-status\";\nimport { listEndpoints } from \"@/lib/endpoints/service\";\nimport Link from \"next/link\";\n\nconst plannedSurfaces = [\n  \"Endpoint and tool management\",\n  \"MCP JSON-RPC runtime\",\n  \"REST mock API\",\n  \"Basic Auth management\",\n  \"OAuth consent and token runtime\",\n  \"Failure simulation and audit\",\n  \"Operator configuration and startup proof\",\n];\n\nexport default async function Home() {\n  const status = getBootstrapStatus();\n  const endpointData = await listEndpoints();\n\n  return (\n    <main className=\"shell app-shell\">\n      <nav className=\"top-nav\" aria-label=\"Primary\">\n        <Link href=\"/\" aria-current=\"page\">Dashboard</Link>\n        <Link href=\"/endpoints\">Endpoints</Link>\n        <Link href=\"/basic-users\">Basic Users</Link>\n        <Link href=\"/oauth-users\">OAuth Users</Link>\n        <Link href=\"/reset\">Reset</Link>\n        <Link href=\"/audit\">Audit</Link>\n      </nav>\n      <section className=\"hero\" aria-labelledby=\"page-title\">\n        <p className=\"eyebrow\">Public test bench</p>\n        <h1 id=\"page-title\">MCP Mock Server</h1>\n        <p className=\"lede\">\n          Public remote MCP mock server for testing no-auth, Basic Auth, mock OAuth bearer tokens,\n          endpoint permissions, and tool-call failure modes.\n        </p>\n      </section>\n\n      <section className=\"status-grid\" aria-label=\"Bootstrap status\">\n        <div>\n          <span>Runtime state</span>\n          <strong>{status.runtimeState}</strong>\n        </div>\n        <div>\n          <span>Log level</span>\n          <strong>{status.logLevel}</strong>\n        </div>\n        <div>\n          <span>Health route</span>\n          <strong>/api/health</strong>\n        </div>\n        <div>\n          <span>Persisted endpoints</span>\n          <strong>{endpointData.total}</strong>\n        </div>\n        <div>\n          <span>Enabled tools</span>\n          <strong>{endpointData.enabled}</strong>\n        </div>\n        <div>\n          <span>Disabled tools</span>\n          <strong>{endpointData.disabled}</strong>\n        </div>\n      </section>\n\n      <section className=\"panel\" aria-labelledby=\"queue-title\">\n        <h2 id=\"queue-title\">Queued feature fronts</h2>\n        <ul>\n          {plannedSurfaces.map((surface) => (\n            <li key={surface}>{surface}</li>\n          ))}\n        </ul>\n      </section>\n    </main>\n  );\n}\nimport type { Metadata } from \"next\";\nimport \"./globals.css\";\n\nexport const metadata: Metadata = {\n  title: \"MCP Mock Server\",\n  description: \"Public remote MCP mock server for auth and tool-call testing.\",\n};\n\nexport default function RootLayout({ children }: Readonly<{ children: React.ReactNode }>) {\n  return (\n    <html lang=\"en\">\n      <body>{children}</body>\n    </html>\n  );\n}\n","exit_code":0,"status":"completed"}}
