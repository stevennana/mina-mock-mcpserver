{"type":"item.completed","item":{"id":"item_20","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,220p' lib/security/root-password.ts\"","aggregated_output":"import { timingSafeEqual } from \"node:crypto\";\n\nfunction safeEqual(left: string, right: string) {\n  const leftBuffer = Buffer.from(left);\n  const rightBuffer = Buffer.from(right);\n  if (leftBuffer.length !== rightBuffer.length) {\n    timingSafeEqual(leftBuffer, leftBuffer);\n    return false;\n  }\n  return timingSafeEqual(leftBuffer, rightBuffer);\n}\n\nexport function verifyRootPassword(candidate: string | null | undefined) {\n  const configured = process.env.ROOT_PASSWORD;\n  if (!configured || !candidate) {\n    return false;\n  }\n  return safeEqual(candidate, configured);\n}\n","exit_code":0,"status":"completed"}}
