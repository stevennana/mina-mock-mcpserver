ointId, name])`\n+- `@@index([endpointId, priority])`\n - `@@index([endpointId])`\n \n ## Seed Defaults\n@@ -82,8 +90,9 @@ Indexes and constraints:\n \n - Endpoint ID: `endpoint_default_echo`\n - Tool name: `echo`\n+- Title: `Echo`\n - Delete code: `12345678`\n - Parameter: `message` at position `0`\n-- Response cases: `default` and `hello-world`\n+- Response cases: `default` at priority `0` and `hello-world` at priority `10`, both with no case-level delay/error configured\n \n The seed uses immutable IDs and unique endpoint-scoped keys, so repeated preparation updates the built-in records without duplicating rows.\ndiff --git a/prisma/schema.prisma b/prisma/schema.prisma\nindex bead4f0..002d36a 100644\n--- a/prisma/schema.prisma\n+++ b/prisma/schema.prisma\n@@ -9,6 +9,7 @@ datasource db {\n model Endpoint {\n   id                    String          @id\n   name                  String          @unique\n+  title                 String          @default(\"\")\n   description           String          @default(\"\")\n   enabled               Boolean         @default(true)\n   protectedDefault      Boolean         @default(false)\n@@ -45,17 +46,24 @@ model EndpointParam {\n }\n \n model ResponseCase {\n-  id            String   @id\n-  endpointId    String\n-  name          String\n-  matchArgsJson String   @default(\"{}\")\n-  responseJson  String\n-  statusCode    Int      @default(200)\n-  isDefault     Boolean  @default(false)\n-  createdAt     DateTime @default(now())\n-  updatedAt     DateTime @updatedAt\n-  endpoint      Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n+  id              String   @id\n+  endpointId      String\n+  name            String\n+  priority        Int      @default(0)\n+  matchArgsJson   String   @default(\"{}\")\n+  responseJson    String\n+  statusCode      Int      @default(200)\n+  delayMs         Int      @default(0)\n+  errorMode       String   @default(\"none\")\n+  errorStatusCode Int?\n+  errorMessage    String?\n+  errorBodyJson   String?\n+  isDefault       Boolean  @default(false)\n+  createdAt       DateTime @default(now())\n+  updatedAt       DateTime @updatedAt\n+  endpoint        Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n \n   @@unique([endpointId, name])\n+  @@index([endpointId, priority])\n   @@index([endpointId])\n }\ndiff --git a/prisma/seed.mjs b/prisma/seed.mjs\nindex 2fdb6ec..72e7d6c 100644\n--- a/prisma/seed.mjs\n+++ b/prisma/seed.mjs\n@@ -12,6 +12,7 @@ export async function seedEndpointDefaults(client = prisma) {\n     where: { id: DEFAULT_ENDPOINT_ID },\n     update: {\n       name: \"echo\",\n+      title: \"Echo\",\n       description: \"Default enabled endpoint for smoke-testing endpoint persistence.\",\n       enabled: true,\n       protectedDefault: true,\n@@ -26,6 +27,7 @@ export async function seedEndpointDefaults(client = prisma) {\n     create: {\n       id: DEFAULT_ENDPOINT_ID,\n       name: \"echo\",\n+      title: \"Echo\",\n       description: \"Default enabled endpoint for smoke-testing endpoint persistence.\",\n       enabled: true,\n       protectedDefault: true,\n@@ -49,17 +51,23 @@ export async function seedEndpointDefaults(client = prisma) {\n           {\n             id: `${DEFAULT_ENDPOINT_ID}_case_default`,\n             name: \"default\",\n+            priority: 0,\n             matchArgsJson: \"{}\",\n             responseJson: JSON.stringify({ ok: true, source: \"default\" }),\n             statusCode: 200,\n+            delayMs: 0,\n+            errorMode: \"none\",\n             isDefault: true,\n           },\n           {\n             id: `${DEFAULT_ENDPOINT_ID}_case_hello`,\n             name: \"hello-world\",\n+            priority: 10,\n             matchArgsJson: JSON.stringify({ message: \"hello\" }),\n             responseJson: JSON.stringify({ ok: true, message: \"world\" }),\n             statusCode: 200,\n+            delayMs: 0,\n+            errorMode: \"none\",\n             isDefault: false,\n           },\n         ],\n@@ -102,18 +110,27 @@ export async function seedEndpointDefaults(client = prisma) {\n       },\n     },\n     update: {\n+      priority: 0,\n       matchArgsJson: \"{}\",\n       responseJson: JSON.stringify({ ok: true, source: \"default\" }),\n       statusCode: 200,\n+      delayMs: 0,\n+      errorMode: \"none\",\n+      errorStatusCode: null,\n+      errorMessage: null,\n+      errorBodyJson: null,\n       isDefault: true,\n     },\n     create: {\n       id: `${DEFAULT_ENDPOINT_ID}_case_default`,\n       endpointId: DEFAULT_ENDPOINT_ID,\n       name: \"default\",\n+      priority: 0,\n       matchArgsJson: \"{}\",\n       responseJson: JSON.stringify({ ok: true, source: \"default\" }),\n       statusCode: 200,\n+      delayMs: 0,\n+      errorMode: \"none\",\n       isDefault: true,\n     },\n   });\n@@ -126,18 +143,27 @@ export async function seedEndpointDefaults(client = prisma) {\n       },\n     },\n     update: {\n+      priority: 10,\n       matchArgsJson: JSON.stringify({ message: \"hello\" }),\n       responseJson: JSON.stringify({ ok: true, message: \"world\" }),\n       statusCode: 200,\n+      delayMs: 0,\n+      errorMode: \"none\",\n+      errorStatusCode: null,\n+      errorMessage: null,\n+      errorBodyJson: null,\n       isDefault: false,\n     },\n     create: {\n       id: `${DEFAULT_ENDPOINT_ID}_case_hello`,\n       endpointId: DEFAULT_ENDPOINT_ID,\n       name: \"hello-world\",\n+      priority: 10,\n       matchArgsJson: JSON.stringify({ message: \"hello\" }),\n       responseJson: JSON.stringify({ ok: true, message: \"world\" }),\n       statusCode: 200,\n+      delayMs: 0,\n+      errorMode: \"none\",\n       isDefault: false,\n     },\n   });\ndiff --git a/tests/unit/db-prepare.test.ts b/tests/unit/db-prepare.test.ts\nindex 4539714..a1e4f79 100644\n--- a/tests/unit/db-prepare.test.ts\n+++ b/tests/unit/db-prepare.test.ts\n@@ -37,10 +37,17 @@ test(\"db:prepare is repeatable and 