  expect(strictMalformed.status()).toBe(401);

  const strictInvalid = await request.post("/mcp/basic", {
    headers: { Authorization: basic("default", "wrong") },
    data: { jsonrpc: "2.0", id: "invalid", method: "tools/list" },
