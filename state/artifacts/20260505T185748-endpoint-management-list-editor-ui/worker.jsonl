 display: block;\n  color: var(--muted);\n  font-size: 0.86rem;\n}\n\n.status-grid strong {\n  display: block;\n  margin-top: 8px;\n  font-size: 1.2rem;\n}\n\n.panel {\n  padding: 22px;\n}\n\n.panel h2 {\n  margin: 0 0 16px;\n  font-size: 1.2rem;\n}\n\n.panel ul {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 10px 24px;\n  margin: 0;\n  padding-left: 20px;\n  color: var(--muted);\n}\n\n.page-header {\n  display: grid;\n  grid-template-columns: minmax(0, 1fr);\n  gap: 18px;\n  margin-bottom: 24px;\n}\n\n.page-header h1 {\n  font-size: 2.35rem;\n}\n\n.lede.compact {\n  max-width: 760px;\n  font-size: 1rem;\n}\n\n.summary-strip {\n  display: grid;\n  grid-template-columns: repeat(3, minmax(0, 1fr));\n  gap: 8px;\n}\n\n.summary-strip span {\n  min-height: 64px;\n  border: 1px solid var(--line);\n  border-radius: 8px;\n  padding: 12px;\n  background: var(--panel);\n  color: var(--muted);\n  font-size: 0.82rem;\n  font-weight: 700;\n  text-transform: uppercase;\n}\n\n.summary-strip strong {\n  display: block;\n  color: var(--fg);\n  font-size: 1.35rem;\n}\n\n.endpoint-layout {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 16px;\n  align-items: start;\n}\n\n.endpoint-list-panel,\n.endpoint-editor-panel,\n.editor-section {\n  border: 1px solid var(--line);\n  border-radius: 8px;\n  background: var(--panel);\n}\n\n.endpoint-list-panel,\n.endpoint-editor-panel {\n  min-width: 0;\n  padding: 16px;\n}\n\n.section-heading-row {\n  display: flex;\n  flex-wrap: wrap;\n  gap: 12px;\n  align-items: flex-start;\n  justify-content: space-between;\n  margin-bottom: 14px;\n}\n\n.section-heading-row h2,\n.editor-section h3 {\n  margin: 0;\n  font-size: 1.05rem;\n}\n\n.section-heading-row p {\n  margin: 4px 0 0;\n  color: var(--muted);\n  font-size: 0.9rem;\n}\n\n.primary-button,\n.secondary-button {\n  min-height: 44px;\n  border: 1px solid transparent;\n  border-radius: 8px;\n  padding: 0 14px;\n  font-weight: 800;\n  cursor: pointer;\n}\n\n.primary-button {\n  background: var(--accent);\n  color: #ffffff;\n}\n\n.secondary-button {\n  border-color: var(--line);\n  background: #f8fafc;\n  color: #26313f;\n}\n\n.primary-button:disabled,\n.secondary-button:disabled {\n  cursor: not-allowed;\n  opacity: 0.55;\n}\n\n.field-label,\n.field-block > span {\n  display: block;\n  margin-bottom: 6px;\n  color: #26313f;\n  font-size: 0.86rem;\n  font-weight: 800;\n}\n\n.text-input,\n.text-area {\n  width: 100%;\n  min-height: 44px;\n  border: 1px solid #cbd3df;\n  border-radius: 8px;\n  padding: 10px 11px;\n  background: #ffffff;\n  color: var(--fg);\n}\n\n.text-area {\n  min-height: 116px;\n  resize: vertical;\n  font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, \"Liberation Mono\", monospace;\n  font-size: 0.88rem;\n  line-height: 1.45;\n}\n\n.text-area.short {\n  min-height: 76px;\n  font-family: inherit;\n}\n\n.field-block {\n  display: block;\n  min-width: 0;\n}\n\n.field-block.wide {\n  grid-column: 1 / -1;\n}\n\n.field-error {\n  margin: 6px 0 0;\n  color: #b42318;\n  font-size: 0.84rem;\n  font-weight: 700;\n}\n\n.form-message {\n  border-radius: 8px;\n  margin: 0 0 14px;\n  padding: 10px 12px;\n  font-size: 0.9rem;\n  font-weight: 800;\n}\n\n.form-message.error {\n  border: 1px solid #f3b6af;\n  background: #fff4f2;\n  color: #9f1f14;\n}\n\n.form-message.success {\n  border: 1px solid #9dd7b5;\n  background: #effaf3;\n  color: #136337;\n}\n\n.form-message.saving,\n.form-message.idle {\n  border: 1px solid var(--line);\n  background: #f8fafc;\n  color: var(--muted);\n}\n\n.form-grid,\n.case-grid {\n  display: grid;\n  grid-template-columns: 1fr;\n  gap: 12px;\n}\n\n.toggle-row,\n.compact-check {\n  min-height: 44px;\n  display: flex;\n  gap: 9px;\n  align-items: center;\n  color: #26313f;\n  font-size: 0.9rem;\n  font-weight: 750;\n}\n\n.toggle-row input,\n.compact-check input {\n  width: 18px;\n  height: 18px;\n  flex: 0 0 auto;\n}\n\n","exit_code":0,"status":"completed"}}
