=> process.stdout.write(chunk));\nserver.stderr.on(\"data\", (chunk) => process.stderr.write(chunk));\n\ntry {\n  await waitForHealth();\n  console.log(`Production-style startup smoke passed at ${healthUrl}`);\n} finally {\n  server.kill(\"SIGTERM\");\n}\n","exit_code":0,"status":"completed"}}
