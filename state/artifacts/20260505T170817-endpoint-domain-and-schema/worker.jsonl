\n  await runDbPrepare(databaseUrl);\\n  await runDbPrepare(databaseUrl);\\n\\n  const previousDatabaseUrl = process.env.DATABASE_URL;\\n  process.env.DATABASE_URL = databaseUrl;\\n  const prisma = createPrismaClient();\\n\\n  try {\\n    assert.equal(await prisma.endpoint.count(), 1);\\n    assert.equal(await prisma.endpointParam.count(), 1);\\n    assert.equal(await prisma.responseCase.count(), 2);\\n\\n    const endpoint = await prisma.endpoint.findUniqueOrThrow({\\n      where: { id: \\\"endpoint_default_echo\\\" },\\n      include: { parameters: true, responseCases: true },\\n    });\\n\\n    assert.equal(endpoint.name, \\\"echo\\\");\\n    assert.equal(endpoint.title, \\\"Echo\\\");\\n    assert.equal(endpoint.enabled, true);\\n    assert.equal(endpoint.protectedDefault, true);\\n    assert.equal(endpoint.parameters[0]?.position, 0);\\n    assert.equal(endpoint.responseCases.some((responseCase) => responseCase.isDefault), true);\\n\\n    const helloCase = endpoint.responseCases.find((responseCase) => responseCase.name === \\\"hello-world\\\");\\n    assert.equal(helloCase?.priority, 10);\\n    assert.equal(helloCase?.delayMs, 0);\\n    assert.equal(helloCase?.errorMode, \\\"none\\\");\\n    assert.equal(helloCase?.errorStatusCode, null);\\n  } finally {\\n    await prisma.$disconnect();\\n    if (previousDatabaseUrl === undefined) {\\n      delete process.env.DATABASE_URL;\\n    } else {\\n      process.env.DATABASE_URL = previousDatabaseUrl;\\n    }\\n  }\\n});\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./state/artifacts/20260505T170343-endpoint-domain-and-schema/worker.jsonl:38:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_18\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc \\\"sed -n '1,260p' docs/generated/db-schema.md\\\"\",\"aggregated_output\":\"# Generated DB Schema\\n\\nGenerated for task `endpoint-domain-and-schema`.\\n\\n## Runtime Database\\n\\n- Provider: SQLite through Prisma.\\n- Default URL: `file:./data/runtime.sqlite`.\\n- Preparation command: `npm run db:prepare`.\\n- Preparation behavior: creates `data/`, applies Prisma migrations, generates Prisma Client, and runs idempotent endpoint seed defaults.\\n- Persistence source of truth: SQLite. `data/bootstrap-state.json` is no longer used by `db:prepare`.\\n\\n## Endpoint\\n\\nStores durable mock tool records. `id` is the immutable internal identifier used by later permission and runtime slices; `name` is the externally visible tool label and may change without changing `id`.\\n\\n| Field | Type | Notes |\\n|---|---|---|\\n| `id` | `String` | Primary key, assigned by domain/seed code. |\\n| `name` | `String` | Unique tool name. |\\n| `title` | `String` | User-facing display title from the endpoint create/edit model. |\\n| `description` | `String` | Human-readable endpoint description. |\\n| `enabled` | `Boolean` | Runtime visibility toggle. |\\n| `protectedDefault` | `Boolean` | Marks built-in defaults that normal flows should protect. |\\n| `deleteCode` | `String?` | Endpoint delete-code storage for later protected delete flows. |\\n| `defaultResponseJson` | `String` | JSON-encoded default response body. |\\n| `failureMode` | `String` | Basic failure simulation mode placeholder, seeded as `none`. |\\n| `failureStatusCode` | `Int?` | Optional forced-error status. |\\n| `failureDelayMs` | `Int` | Optional delay duration, seeded as `0`. |\\n| `failureMessage` | `String?` | Optional forced-error message. |\\n| `malformedResponseJson` | `String?` | Optional malformed response payload for later runtime slices. |\\n| `createdAt` | `DateTime` | Audit-ready creation timestamp. |\\n| `updatedAt` | `DateTime` | Audit-ready update timestamp maintained by Prisma. |\\n\\n## EndpointParam\\n\\nStores ordered parameter definitions for each endpoint. The schema supports the MVP limit of up to three parameters by position; domain validation in the next slice owns the user-facing limit enforcement.\\n\\n| Field | Type | Notes |\\n|---|---|---|\\n| `id` | `String` | Primary key, assigned by domain/seed code. |\\n| `endpointId` | `String` | Required relation to `Endpoint`, cascades on endpoint delete. |\\n| `position` | `Int` | Parameter order. Unique per endpoint. |\\n| `name` | `String` | Parameter key. Unique per endpoint. |\\n| `label` | `String?` | Optional UI label. |\\n| `description` | `String` | Parameter help text. |\\n| `type` | `String` | Parameter type placeholder, seeded as `string`. |\\n| `required` | `Boolean` | Required argument flag. |\\n| `defaultValueJson` | `String?` | Optional JSON-encoded default value. |\\n| `createdAt` | `DateTime` | Audit-ready creation timestamp. |\\n| `updatedAt` | `DateTime` | Audit-ready update timestamp maintained by Prisma. |\\n\\nIndexes and constraints:\\n\\n- `@@unique([endpointId, position])`\\n- `@@unique([endpointId, name])`\\n- `@@index([endpointId])`\\n\\n## ResponseCase\\n\\nStores exact-match response cases and a default case marker. Matching semantics are intentionally deferred to the endpoint validation and matching task.\\n\\n| Field | Type | Notes |\\n|---|---|---|\\n| `id` | `String` | Primary key, assigned by domain/seed code. |\\n| `endpointId` | `String` | Required relation to `Endpoint`, cascades on endpoint delete. |\\n| `name` | `String` | Case name. Unique per endpoint. |\\n| `priority` | `Int` | Case selection ordering placeholder for later matching logic. |\\n| `matchArgsJson` | `String` | JSON-encoded exact-match argument object. |\\n| `responseJson` | `String` | JSON-encoded response body. |\\n| `statusCode` | `Int` | HTTP/runtime status placeholder for later adapters. |\\n| `delayMs` | `Int` | Case-level delay duration for later failure simulation/runtime slices. |\\n| `errorMode` | `String` | Case-level error mode placeholder, seeded as `none`. |\\n| `errorStatusCode` | `Int?` | Optional case-level forced-error status. |\\n| `errorMessage` | `String?` | Optional case-level forced-error message. |\\n| `errorBodyJson` | `String?` | Optional JSON-encoded case-level error body. |\\n| `isDefault` | `Boolean` | Marks the default/no-match case. |\\n| `createdAt` | `DateTime` | Audit-ready creation timestamp. |\\n| `updatedAt` | `DateTime` | Audit-ready update timestamp maintained by Prisma. |\\n\\nIndexes and constraints:\\n\\n- `@@unique([endpointId, name])`\\n- `@@index([endpointId, priority])`\\n- `@@index([endpointId])`\\n\\n## Seed Defaults\\n\\n`npm run db:prepare` upserts one protected enabled endpoint:\\n\\n- Endpoint ID: `endpoint_default_echo`\\n- Tool name: `echo`\\n- Title: `Echo`\\n- Delete code: `12345678`\\n- Parameter: `message` at position `0`\\n- Response cases: `default` at priority `0` and `hello-world` at priority `10`, both with no case-level delay/error configured\\n\\nThe seed uses immutable IDs and unique endpoint-scoped keys, so repeated preparation updates the built-in records without duplicating rows.\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./state/artifacts/20260505T170343-endpoint-domain-and-schema/worker.jsonl:39:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_19\",\"type\":\"agent_message\",\"text\":\"The persistence implementation is present: Prisma schema, migrations, seed, generated schema docs, and a repeatability unit test. I’m checking the supporting client/migrations next, then I’ll run the required gates against this checkout.\"}}\n./state/artifacts/20260505T170343-endpoint-domain-and-schema/worker.jsonl:40:{\"type\":\"item.started\",\"item\":{\"id\":\"item_20\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc 'rg -n \\\"createPrismaClient|bootstrap-state|DATABASE_URL|PrismaBetterSqlite3|endpoint_default_echo\\\" .'\",\"aggregated_output\":\"\",\"exit_code\":null,\"status\":\"in_progress\"}}\n./state/artifacts/20260505T170343-endpoint-domain-and-schema/worker.jsonl:41:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_20\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc 'rg -n \\\"createPrismaClient|bootstrap-state|DATABASE_URL|PrismaBetterSqlite3|endpoint_default_echo\\\" .'\",\"aggregated_output\":\"./prisma.config.ts:3:const databaseUrl = process.env.DATABASE_URL ?? \\\"file:./data/runtime.sqlite\\\";\\n./lib/db/client.ts:1:import { PrismaBetterSqlite3 } from \\\"@prisma/adapter-better-sqlite3\\\";\\n./lib/db/client.ts:4:export const DEFAULT_DATABASE_URL = \\\"file:./data/runtime.sqlite\\\";\\n./lib/db/client.ts:7:  return process.env.DATABASE_URL ?? DEFAULT_DATABASE_URL;\\n./lib/db/client.ts:10:export function createPrismaClient() {\\n./lib/db/client.ts:11:  const adapter = new PrismaBetterSqlite3({ url: getDatabaseUrl() });\\n./tests/unit/db-prepare.test.ts:8:import { createPrismaClient } from \\\"@/lib/db/client\\\";\\n./tests/unit/db-prepare.test.ts:14:    env: { ...process.env, DATABASE_URL: databaseUrl },\\n./tests/unit/db-prepare.test.ts:25:  const previousDatabaseUrl = process.env.DATABASE_URL;\\n./tests/unit/db-prepare.test.ts:26:  process.env.DATABASE_URL = databaseUrl;\\n./tests/unit/db-prepare.test.ts:27:  const prisma = createPrismaClient();\\n./tests/unit/db-prepare.test.ts:35:      where: { id: \\\"endpoint_default_echo\\\" },\\n./tests/unit/db-prepare.test.ts:54:      delete process.env.DATABASE_URL;\\n./tests/unit/db-prepare.test.ts:56:      process.env.DATABASE_URL = previousDatabaseUrl;\\n./prisma/seed.mjs:2:import { PrismaBetterSqlite3 } from \\\"@prisma/adapter-better-sqlite3\\\";\\n./prisma/seed.mjs:4:export const DEFAULT_ENDPOINT_ID = \\\"endpoint_default_echo\\\";\\n./prisma/seed.mjs:6:const databaseUrl = process.env.DATABASE_URL ?? \\\"file:./data/runtime.sqlite\\\";\\n./prisma/seed.mjs:7:const adapter = new PrismaBetterSqlite3({ url: databaseUrl });\\n./PRD/mcp_mock_server_prd.md:2180:| `DATABASE_URL` | no | `file:./data/mcp-mock.sqlite` | SQLite database path. |\\n./state/artifacts/20260505T164526-endpoint-domain-and-schema/worker.jsonl:19:{\\\"type\\\":\\\"item.completed\\\",\\\"item\\\":{\\\"id\\\":\\\"item_8\\\",\\\"type\\\":\\\"command_execution\\\",\\\"command\\\":\\\"/bin/zsh -lc \\\\\\\"sed -n '1,320p' docs/exec-plans/active/001-endpoint-domain-and-schema.md\\\\\\\"\\\",\\\"aggregated_output\\\":\\\"# Endpoint Persistence Schema and Seed Defaults\\\\n\\\\n```json taskmeta\\\\n{\\\\n  \\\\\\\"id\\\\\\\": \\\\\\\"endpoint-domain-and-schema\\\\\\\",\\\\n  \\\\\\\"title\\\\\\\": \\\\\\\"Endpoint Persistence Schema and Seed Defaults\\\\\\\",\\\\n  \\\\\\\"order\\\\\\\": 1,\\\\n  \\\\\\\"status\\\\\\\": \\\\\\\"active\\\\\\\",\\\\n  \\\\\\\"next_task_on_success\\\\\\\": \\\\\\\"endpoint-validation-and-matching\\\\\\\",\\\\n  \\\\\\\"prompt_docs\\\\\\\": [\\\\n    \\\\\\\"AGENTS.md\\\\\\\",\\\\n    \\\\\\\"ARCHITECTURE.md\\\\\\\",\\\\n    \\\\\\\"docs/PRODUCT_SENSE.md\\\\\\\",\\\\n    \\\\\\\"docs/DESIGN.md\\\\\\\",\\\\n    \\\\\\\"docs/references/prd-analysis.md\\\\\\\",\\\\n    \\\\\\\"docs/product-specs/endpoint-tool-management.md\\\\\\\"\\\\n  ],\\\\n  \\\\\\\"required_commands\\\\\\\": [\\\\n    \\\\\\\"npm run db:prepare\\\\\\\",\\\\n    \\\\\\\"npm run test:unit\\\\\\\",\\\\n    \\\\\\\"npm run verify\\\\\\\"\\\\n  ],\\\\n  \\\\\\\"required_files\\\\\\\": [],\\\\n  \\\\\\\"human_review_triggers\\\\\\\": [\\\\n    \\\\\\\"The task broadens into unrelated feature fronts.\\\\\\\",\\\\n    \\\\\\\"Required checks do not prove the claimed behavior.\\\\\\\",\\\\n    \\\\\\\"Implementation changes contradict the product spec or security/reliability docs.\\\\\\\"\\\\n  ],\\\\n  \\\\\\\"promotion_mode\\\\\\\": \\\\\\\"deterministic\\\\\\\"\\\\n}\\\\n```\\\\n\\\\n## Objective\\\\n\\\\nReplace the bootstrap runtime placeholder with durable SQLite/Prisma persistence for endpoint/tool data and deterministic seed defaults.\\\\n\\\\n## Clarity notes\\\\n\\\\n- This task is only the persistence foundation for endpoints; it should not implement forms, MCP routes, REST routes, or auth behavior.\\\\n- The schema must use immutable endpoint IDs internally because later OAuth permissions should not drift when a tool name changes.\\\\n- `npm run db:prepare` is the deterministic runtime-prep command used by Ralph and startup smoke, so keep the command name stable.\\\\n- Seed behavior should be idempotent and safe to run before every test or startup smoke.\\\\n\\\\n## Expected result\\\\n\\\\n- Prisma and SQLite are wired into the repo with migrations/schema files and deterministic runtime preparation.\\\\n- Tables or models exist for endpoints, parameters, response cases, audit-ready timestamps, and enough seed defaults for later slices.\\\\n- Seed data can be recreated without duplicating rows or weakening protected/default invariants.\\\\n- `docs/generated/db-schema.md` records the schema shape and persistence assumptions.\\\\n\\\\n## Objections / risks to avoid\\\\n\\\\n- Do not keep using `data/bootstrap-state.json` as the real persistence mechanism after this task.\\\\n- Do not make endpoint names the only durable identifier.\\\\n- Do not add UI screens or external protocol routes in this persistence task.\\\\n- Do not leave migrations or seed commands dependent on local manual steps.\\\\n\\\\n## Scope\\\\n\\\\n- Add Prisma/SQLite dependencies, schema, migration or sync path, generated client setup, and repo-local DB configuration.\\\\n- Define endpoint, parameter, response case, and timestamp fields required by the PRD for MVP endpoint management.\\\\n- Implement idempotent seed preparation for at least one representative enabled endpoint and any protected defaults needed by endpoint flows.\\\\n- Update `scripts/db-prepare.mjs` to prepare SQLite state deterministically.\\\\n- Add unit coverage or command-level assertions that `db:prepare` can run repeatedly.\\\\n\\\\n## Out of scope\\\\n\\\\n- Endpoint validators and exact-match response selection beyond simple schema constraints.\\\\n- Endpoint management UI.\\\\n- MCP, REST, Basic Auth, or OAuth runtime behavior.\\\\n- Root reset behavior; that has its own task.\\\\n\\\\n## Exit criteria\\\\n\\\\n1. `npm run db:prepare` creates or updates the SQLite runtime state successfully from a clean checkout.\\\\n2. Running `npm run db:prepare` twice is safe and does not duplicate seed data.\\\\n3. The schema can represent endpoint names, descriptions, enabled state, up to three parameters, response cases, default responses, delete codes, and basic failure config fields.\\\\n4. `docs/generated/db-schema.md` matches the implemented persistence shape.\\\\n5. All required checks pass.\\\\n\\\\n## Required checks\\\\n\\\\n- npm run db:prepare\\\\n- npm run test:unit\\\\n- npm run verify\\\\n\\\\n## Implementation notes\\\\n\\\\n- Use the installed `prisma-cli` skill guidance if Prisma command details are needed.\\\\n- Keep repositories thin and prepare for domain services in the next task.\\\\n\\\\n## Docs to update\\\\n\\\\n- docs/PRODUCT_SENSE.md\\\\n- docs/DESIGN.md\\\\n- docs/references/prd-analysis.md\\\\n\\\\n## Evaluator notes\\\\n\\\\nRequired commands are mandatory promotion gates, not suggestions.\\\\nDo not promote if any required check fails.\\\\nDo not accept broad feature work outside this task.\\\\nConfirm that this task maps to the primary product spec `endpoint-tool-management.md` or is explicitly final hardening.\\\\n\\\\n## Progress log\\\\n\\\\n- Start here. Append timestamped progress notes as work lands.\\\\n- Note when existing partial implementations were found and reused instead of replaced.\\\\n- 2026-05-05T17:05:00+09:00 - Found only the bootstrap placeholder (`scripts/db-prepare.mjs` writing `data/bootstrap-state.json`) and reused the existing `db:prepare` command name while replacing its implementation with Prisma migration/client/seed preparation.\\\\n- 2026-05-05T17:10:00+09:00 - Added Prisma SQLite schema and initial migration for endpoints, ordered parameters, response cases, timestamps, delete-code/default/failure fields, and immutable endpoint IDs.\\\\n- 2026-05-05T17:15:00+09:00 - Added idempotent default seed for protected enabled `endpoint_default_echo` plus a repeatability unit 