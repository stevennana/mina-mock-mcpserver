  padding-top: 28px;
  padding-bottom: 28px;
}

.oauth-panel {
  width: 100%;
  max-width: 820px;
  border: 1px solid var(--line);
  border-radius: 8px;
  padding: 18px;
  background: var(--panel);
}

.oauth-panel h1 {
  font-size: 2rem;
}

.oauth-detail-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 10px;
  margin: 18px 0;
}

.oauth-detail-grid div {
  min-width: 0;
  border: 1px solid #e4e9f0;
  border-radius: 8px;
  padding: 10px;
  background: #fbfcfe;
}

.oauth-detail-grid dt {
  color: var(--muted);
  font-size: 0.76rem;
  font-weight: 850;
  text-transform: uppercase;
}

.oauth-detail-grid dd {
  margin: 5px 0 0;
  overflow-wrap: anywhere;
  color: #26313f;
  font-weight: 750;
}

.oauth-form {
  display: grid;
  gap: 12px;
  margin-top: 16px;
}

.oauth-form .primary-button {
  width: fit-content;
}

.oauth-permissions {
  display: grid;
  gap: 8px;
  min-width: 0;
  border: 0;
  margin: 0;
  padding: 0;
}

.oauth-permissions legend {
  margin-bottom: 8px;
  color: #26313f;
  font-size: 0.92rem;
  font-weight: 850;
}

.audit-panel {
  overflow-x: auto;
  border: 1px solid var(--line);
  border-radius: 8px;
  background: var(--panel);
}

}

.evidence-panel.compact pre {
  min-height: 72px;
}

@media (max-width: 720px) {
  .shell {
    width: min(100% - 24px, 560px);
    padding: 28px 0;
  }

  .status-grid,
  .panel ul,
  .summary-strip,
  .oauth-detail-grid {
    grid-template-columns: 1fr;
  }
}

@media (min-width: 760px) {
  .page-header {
    grid-template-columns: minmax(0, 1fr) 340px;
    align-items: end;
  }

  .form-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .console-controls,
  .console-evidence-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .case-grid {
    grid-template-columns: minmax(0, 1fr) 140px 160px;
    align-items: end;
  }

  .checkbox-grid,
  .secret-callout,
  .oauth-detail-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .secret-callout {
    grid-template-columns: minmax(0, 1fr) auto;
  }

  .parameter-editor {
    grid-template-columns: minmax(120px, 1fr) 120px 120px minmax(120px, 1fr) auto;
    align-items: start;
  }

  .parameter-description {
    grid-column: 1 / -1;
  }
}

