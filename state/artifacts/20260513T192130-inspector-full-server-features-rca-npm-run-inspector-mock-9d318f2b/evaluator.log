t-regenerated through normal public UI/API flows\\ndocs/product-specs/oauth-consent-and-token-runtime.md:36:- Non-built-in OAuth client CRUD validates client ID shape, redirect URI shape, TTL presets, unique client IDs, and existing allowed endpoint IDs\\ndocs/product-specs/oauth-consent-and-token-runtime.md:39:- Consent endpoint selection must be a subset of the registered OAuth client's allowed endpoint IDs\\ndocs/product-specs/oauth-consent-and-token-runtime.md:40:- Client-credentials requested scopes must never expand beyond the registered OAuth client's allowed endpoint IDs\\ndocs/product-specs/oauth-consent-and-token-runtime.md:45:- Authorization-code browser flow selects endpoint permissions, exchanges code for token, calls /mcp/oauth successfully for allowed endpoint, receives 403 for denied endpoint, revokes token and receives 401\\napp/api/oauth-clients/[id]/route.ts:1:import { oauthClientErrorResponse, oauthClientUpdateInputFromBody } from \\\"@/lib/oauth/api\\\";\\napp/api/oauth-clients/[id]/route.ts:2:import { deleteOAuthClient, updateOAuthClient } from \\\"@/lib/oauth/service\\\";\\napp/api/oauth-clients/[id]/route.ts:7:    const client = await updateOAuthClient(id, oauthClientUpdateInputFromBody(await request.json()));\\napp/api/oauth-clients/[id]/route.ts:10:    return oauthClientErrorResponse(error);\\napp/api/oauth-clients/[id]/route.ts:17:    const client = await deleteOAuthClient(id);\\napp/api/oauth-clients/[id]/route.ts:20:    return oauthClientErrorResponse(error);\\ntests/e2e/oauth-clients.spec.ts:5:test(\\\"OAuth clients management UI protects default, shows secrets once, and persists allowed endpoints @ui-oauth-clients\\\", async ({\\ntests/e2e/oauth-clients.spec.ts:11:  await page.goto(\\\"/oauth-clients\\\");\\ntests/e2e/oauth-clients.spec.ts:12:  await expect(page.getByRole(\\\"heading\\\", { name: \\\"OAuth clients\\\" })).toBeVisible();\\ntests/e2e/oauth-clients.spec.ts:24:  const lockedResponse = await request.patch(\\\"/api/oauth-cli