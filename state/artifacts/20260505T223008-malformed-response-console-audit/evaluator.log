  if (body !== null && typeof body === "object" && !Array.isArray(body) && "arguments" in body) {
    return (body as { arguments?: unknown }).arguments ?? {};
  }
  return body;
}

function restToolCallHttpResponse(response: RestToolCallResponse, principal: string) {
