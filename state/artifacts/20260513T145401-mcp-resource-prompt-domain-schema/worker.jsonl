eEndpoint[]\n\n  @@index([code])\n  @@index([oauthClientId, oauthUserId])\n  @@index([expiresAt])\n}\n\nmodel OAuthAuthorizationCodeEndpoint {\n  authorizationCodeId String\n  endpointId          String\n  createdAt           DateTime               @default(now())\n  authorizationCode   OAuthAuthorizationCode @relation(fields: [authorizationCodeId], references: [id], onDelete: Cascade)\n  endpoint            Endpoint               @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n\n  @@id([authorizationCodeId, endpointId])\n  @@index([endpointId])\n}\n\nmodel OAuthIssuedToken {\n  id                      String      @id\n  jti                     String      @unique\n  oauthClientId           String\n  oauthUserId             String?\n  grantType               String\n  scope                   String\n  issuer                  String      @default(\"http://localhost:3000\")\n  resource                String\n  endpointPermissionsJson String      @default(\"[]\")\n  issuedAt                DateTime\n  expiresAt               DateTime\n  revokedAt               DateTime?\n  createdAt               DateTime    @default(now())\n  oauthClient             OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)\n  oauthUser               OAuthUser?  @relation(fields: [oauthUserId], references: [id], onDelete: Cascade)\n\n  @@index([jti])\n  @@index([oauthClientId, oauthUserId])\n  @@index([expiresAt])\n  @@index([revokedAt])\n}\n","exit_code":0,"status":"completed"}}
