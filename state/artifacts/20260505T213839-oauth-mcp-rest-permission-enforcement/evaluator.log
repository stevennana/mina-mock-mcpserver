efault\",\n      client_secret: \"wrong\",\n    },\n  });\n  expect(invalidClient.status()).toBe(400);\n  expect(await invalidClient.json()).toMatchObject({ error: \"invalid_grant\" });\n});\n","exit_code":0,"status":"completed"}}
