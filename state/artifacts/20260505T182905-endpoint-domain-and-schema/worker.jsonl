ue);\\n    assert.equal(endpoint.parameters[0]?.position, 0);\\n    assert.equal(endpoint.responseCases.some((responseCase) => responseCase.isDefault), true);\\n\\n    const helloCase = endpoint.responseCases.find((responseCase) => responseCase.name === \\\"hello-world\\\");\\n    assert.equal(helloCase?.priority, 10);\\n    assert.equal(helloCase?.delayMs, 0);\\n    assert.equal(helloCase?.errorMode, \\\"none\\\");\\n    assert.equal(helloCase?.errorStatusCode, null);\\n  } finally {\\n    await prisma.$disconnect();\\n    if (previousDatabaseUrl === undefined) {\\n      delete process.env.DATABASE_URL;\\n    } else {\\n      process.env.DATABASE_URL = previousDatabaseUrl;\\n    }\\n  }\\n});\\n\",\"exit_code\":0,\"status\":\"completed\"}}\n./state/artifacts/20260505T165839-endpoint-domain-and-schema/evaluator.log:2075:./state/artifacts/20260505T163232-endpoint-domain-and-schema/evaluator.log:2334:./state/artifacts/20260505T162122-endpoint-domain-and-schema/evaluator.log:2126:./state/artifacts/20260505T162122-endpoint-domain-and-schema/worker.jsonl:83:{\"type\":\"item.completed\",\"item\":{\"id\":\"item_42\",\"type\":\"command_execution\",\"command\":\"/bin/zsh -lc 'npm run db:prepare'\",\"aggregated_output\":\"Loaded Prisma config from prisma.config.ts.\\n\\nPrisma schema loaded from prisma/schema.prisma.\\nDatasource \\\"db\\\": SQLite database \\\"runtime.sqlite\\\" at \\\"file:./data/runtime.sqlite\\\"\\n\\n2 migrations found in prisma/migrations\\n\\nApplying migration `202605050002_endpoint_title_response_case_config`\\n\\nThe following migration(s) have been applied:\\n\\nmigrations/\\n  └─ 202605050002_endpoint_title_response_case_config/\\n    └─ migration.sql\\n\\nAll migrations have been successfully applied.\\nLoaded Prisma config from prisma.config.ts.\\n\\nPrisma schema loaded from prisma/schema.prisma.\\n\\n✔ Generated Prisma Client (v7.8.0) to ./node_modules/@prisma/client in 48ms\\n\\nStart by importing your Prisma Client (See: https://pris.ly/d/im