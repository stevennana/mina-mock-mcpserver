enError extends Error {\n  constructor(\n    public readonly code: \"invalid_request\" | \"invalid_client\" | \"invalid_grant\" | \"unsupported_grant_type\",\n    message: string,\n    public readonly status = code === \"invalid_client\" ? 401 : 400,\n  ) {\n","exit_code":0,"status":"completed"}}
