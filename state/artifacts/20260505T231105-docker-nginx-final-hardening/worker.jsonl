{"type":"item.completed","item":{"id":"item_35","type":"command_execution","command":"/bin/zsh -lc \"sed -n '1,260p' prisma/schema.prisma\"","aggregated_output":"generator client {\n  provider = \"prisma-client-js\"\n}\n\ndatasource db {\n  provider = \"sqlite\"\n}\n\nmodel Endpoint {\n  id                    String          @id\n  name                  String          @unique\n  title                 String          @default(\"\")\n  description           String          @default(\"\")\n  enabled               Boolean         @default(true)\n  protectedDefault      Boolean         @default(false)\n  deleteCode            String?\n  defaultResponseJson   String          @default(\"{}\")\n  failureMode           String          @default(\"none\")\n  failureStatusCode     Int?\n  failureDelayMs        Int             @default(0)\n  failureMessage        String?\n  malformedResponseJson String?\n  createdAt             DateTime        @default(now())\n  updatedAt             DateTime        @updatedAt\n  parameters            EndpointParam[]\n  responseCases         ResponseCase[]\n  oauthClientAllowances OAuthClientAllowedEndpoint[]\n  oauthCodePermissions  OAuthAuthorizationCodeEndpoint[]\n}\n\nmodel EndpointParam {\n  id               String   @id\n  endpointId       String\n  position         Int\n  name             String\n  label            String?\n  description      String   @default(\"\")\n  type             String   @default(\"string\")\n  required         Boolean  @default(false)\n  defaultValueJson String?\n  createdAt        DateTime @default(now())\n  updatedAt        DateTime @updatedAt\n  endpoint         Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n\n  @@unique([endpointId, position])\n  @@unique([endpointId, name])\n  @@index([endpointId])\n}\n\nmodel ResponseCase {\n  id              String   @id\n  endpointId      String\n  name            String\n  priority        Int      @default(0)\n  matchArgsJson   String   @default(\"{}\")\n  responseJson    String\n  statusCode      Int      @default(200)\n  delayMs         Int      @default(0)\n  errorMode       String   @default(\"none\")\n  errorStatusCode Int?\n  errorMessage    String?\n  errorBodyJson   String?\n  isDefault       Boolean  @default(false)\n  createdAt       DateTime @default(now())\n  updatedAt       DateTime @updatedAt\n  endpoint        Endpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n\n  @@unique([endpointId, name])\n  @@index([endpointId, priority])\n  @@index([endpointId])\n}\n\nmodel AuditEvent {\n  id             String   @id\n  eventType      String\n  subjectType    String\n  subjectId      String?\n  subjectName    String?\n  outcome        String\n  actorType      String   @default(\"public\")\n  metadataJson   String   @default(\"{}\")\n  createdAt      DateTime @default(now())\n\n  @@index([eventType, createdAt])\n  @@index([subjectType, subjectId])\n}\n\nmodel ServerSetting {\n  key       String   @id\n  value     String\n  updatedAt DateTime @updatedAt\n}\n\nmodel BasicUser {\n  id           String   @id\n  username     String   @unique\n  passwordHash String\n  enabled      Boolean  @default(true)\n  builtIn      Boolean  @default(false)\n  createdAt    DateTime @default(now())\n  updatedAt    DateTime @updatedAt\n\n  @@index([builtIn, username])\n}\n\nmodel OAuthUser {\n  id                    String   @id\n  username              String   @unique\n  passwordHash          String\n  enabled               Boolean  @default(true)\n  builtIn               Boolean  @default(false)\n  accessTokenTtlSeconds Int      @default(3600)\n  createdAt             DateTime @default(now())\n  updatedAt             DateTime @updatedAt\n  authorizationCodes    OAuthAuthorizationCode[]\n  issuedTokens          OAuthIssuedToken[]\n\n  @@index([builtIn, username])\n}\n\nmodel OAuthClient {\n  id                          String                       @id\n  clientId                    String                       @unique\n  displayName                 String                       @default(\"\")\n  secretHash                  String\n  enabled                     Boolean                      @default(true)\n  builtIn                     Boolean                      @default(false)\n  redirectUrisJson            String                       @default(\"[]\")\n  clientCredentialsTtlSeconds Int                          @default(3600)\n  createdAt                   DateTime                     @default(now())\n  updatedAt                   DateTime                     @updatedAt\n  allowedEndpoints            OAuthClientAllowedEndpoint[]\n  authorizationCodes          OAuthAuthorizationCode[]\n  issuedTokens                OAuthIssuedToken[]\n\n  @@index([builtIn, clientId])\n}\n\nmodel OAuthClientAllowedEndpoint {\n  oauthClientId String\n  endpointId    String\n  createdAt     DateTime    @default(now())\n  oauthClient   OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)\n  endpoint      Endpoint    @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n\n  @@id([oauthClientId, endpointId])\n  @@index([endpointId])\n}\n\nmodel OAuthAuthorizationCode {\n  id                  String                           @id\n  code                String                           @unique\n  oauthClientId       String\n  oauthUserId         String\n  redirectUri         String\n  resource            String\n  state               String?\n  expiresAt           DateTime\n  usedAt              DateTime?\n  createdAt           DateTime                         @default(now())\n  oauthClient         OAuthClient                      @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)\n  oauthUser           OAuthUser                        @relation(fields: [oauthUserId], references: [id], onDelete: Cascade)\n  selectedEndpoints   OAuthAuthorizationCodeEndpoint[]\n\n  @@index([code])\n  @@index([oauthClientId, oauthUserId])\n  @@index([expiresAt])\n}\n\nmodel OAuthAuthorizationCodeEndpoint {\n  authorizationCodeId String\n  endpointId          String\n  createdAt           DateTime               @default(now())\n  authorizationCode   OAuthAuthorizationCode @relation(fields: [authorizationCodeId], references: [id], onDelete: Cascade)\n  endpoint            Endpoint               @relation(fields: [endpointId], references: [id], onDelete: Cascade)\n\n  @@id([authorizationCodeId, endpointId])\n  @@index([endpointId])\n}\n\nmodel OAuthIssuedToken {\n  id                      String      @id\n  jti                     String      @unique\n  oauthClientId           String\n  oauthUserId             String?\n  grantType               String\n  scope                   String\n  issuer                  String      @default(\"http://localhost:3000\")\n  resource                String\n  endpointPermissionsJson String      @default(\"[]\")\n  issuedAt                DateTime\n  expiresAt               DateTime\n  revokedAt               DateTime?\n  createdAt               DateTime    @default(now())\n  oauthClient             OAuthClient @relation(fields: [oauthClientId], references: [id], onDelete: Cascade)\n  oauthUser               OAuthUser?  @relation(fields: [oauthUserId], references: [id], onDelete: Cascade)\n\n  @@index([jti])\n  @@index([oauthClientId, oauthUserId])\n  @@index([expiresAt])\n  @@index([revokedAt])\n}\n","exit_code":0,"status":"completed"}}
