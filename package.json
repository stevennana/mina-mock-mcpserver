{
  "name": "mina-mock-mcpserver",
  "version": "1.0.2",
  "description": "Public remote MCP mock server and web UI for testing MCP auth and tool calls.",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1 --port 3100",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "db:prepare": "node scripts/db-prepare.mjs",
    "test:unit": "node --import tsx --test --test-concurrency=1 \"tests/unit/**/*.test.ts\"",
    "test:e2e": "playwright test",
    "test": "npm run test:unit && npm run test:e2e",
    "start:smoke": "node scripts/start-smoke.mjs",
    "start:logged": "node scripts/start-logged.mjs",
    "start:tls": "node scripts/start-tls.mjs",
    "start:tls:smoke": "node scripts/tls-smoke.mjs",
    "cert:dev": "node scripts/dev-cert.mjs",
    "inspector": "npx -y @modelcontextprotocol/inspector@0.21.2",
    "inspector:mcp:none": "npx -y @modelcontextprotocol/inspector@0.21.2 --config ./config/mcp-inspector.local.json --server mina-mock-none",
    "inspector:mcp:basic": "npx -y @modelcontextprotocol/inspector@0.21.2 --config ./config/mcp-inspector.local.json --server mina-mock-basic",
    "inspector:mcp:oauth": "npx -y @modelcontextprotocol/inspector@0.21.2 --config ./config/mcp-inspector.local.json --server mina-mock-oauth",
    "inspector:mcp:sse": "npx -y @modelcontextprotocol/inspector@0.21.2 --config ./config/mcp-inspector.local.json --server mina-mock-sse-none",
    "inspector:cli:list": "npx -y @modelcontextprotocol/inspector@0.21.2 --cli http://127.0.0.1:3100/mcp/none --transport http --method tools/list",
    "inspector:cli:call:echo": "npx -y @modelcontextprotocol/inspector@0.21.2 --cli http://127.0.0.1:3100/mcp/none --transport http --method tools/call --tool-name echo --tool-arg message=hello",
    "inspector:cli:basic:list": "npx -y @modelcontextprotocol/inspector@0.21.2 --cli http://127.0.0.1:3100/mcp/basic --transport http --method tools/list --header \"Authorization: Basic ZGVmYXVsdDpkZWZhdWx0\"",
    "inspector:cli:sse:list": "npx -y @modelcontextprotocol/inspector@0.21.2 --cli http://127.0.0.1:3100/sse/none --transport sse --method tools/list",
    "inspector:ui": "node scripts/standalone-inspector-server.mjs",
    "inspector:mock": "node scripts/mock-inspector.mjs",
    "verify": "npm run lint && npm run typecheck && npm run build && npm run test:unit && npm run test:e2e && npm run start:smoke"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "better-sqlite3": "^12.9.0",
    "next": "^15.3.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@playwright/test": "^1.52.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.3",
    "eslint": "^9.26.0",
    "eslint-config-next": "^15.3.2",
    "prisma": "^7.8.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  },
  "private": true
}
